# ── Railway sets DATABASE_URL and PORT automatically ──────────────────────────
NODE_ENV=production
PORT=4000
DATABASE_URL=postgresql://...  # provided by Railway Postgres plugin

# ── Auth ───────────────────────────────────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-secure-password
JWT_SECRET=generat
e-a-long-random-string
JWT_EXPIRES_IN=12h

# ── CORS ───────────────────────────────────────────────────────────────────────
# Add your Railway backend URL here if needed (ifnbl.com is already in the default list)
CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000,https://ifnbl.com,https://www.ifnbl.com,https://keenan34.github.io
